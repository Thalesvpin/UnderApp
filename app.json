{
  "expo": {
    "name": "UnderApp",
    "slug": "underapp",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./src/assets/logo.png",
    "scheme": "underapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./src/assets/logo.png",
        "monochromeImage": "./src/assets/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.thalesvpinheiro.underapp"
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#45bce4",
          "dark": {
            "backgroundColor": "#45bce4"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c4afc66e-6736-4eb6-bcc4-e199040dd652"
      }
    },
    "owner": "thalesvpinheiro"
  }
}
